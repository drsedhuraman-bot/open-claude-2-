# Binance API credentials
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Set to true to use Binance Testnet (recommended for testing)
# Testnet: https://testnet.binance.vision/
USE_TESTNET=true

# Trading bot settings
BOT_SYMBOL=BTCUSDT
BOT_INTERVAL=1h
BOT_STRATEGY=ma_crossover
BOT_TRADE_AMOUNT=10.0        # USDT amount per trade
BOT_MAX_OPEN_TRADES=3
BOT_STOP_LOSS_PCT=2.0        # Stop loss percentage
BOT_TAKE_PROFIT_PCT=4.0      # Take profit percentage

# MA Crossover strategy settings
MA_FAST_PERIOD=9
MA_SLOW_PERIOD=21

# RSI strategy settings
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# Logging
LOG_LEVEL=INFO
LOG_FILE=trader.log
